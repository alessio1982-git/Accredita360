{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "accredita360.vercel.app" }],
      "destination": "https://accredita360s.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
